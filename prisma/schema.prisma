generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

// 동의 항목을 필수/선택으로 분리 저장 (PIPA 제22조 — 항목별 개별 동의)
enum ConsentType {
  TERMS                  // 이용약관 (필수)
  PRIVACY_REQUIRED       // 개인정보 수집·이용 필수 동의
  MARKETING              // 마케팅 수신 (선택)
  THIRD_PARTY_PROVISION  // 제3자 제공 (선택)
  SENSITIVE_UNIQUE_ID    // 고유식별정보(주민번호 등) 처리 (별도 동의)
}

enum PiiAction {
  READ     // 마스킹 상태 조회
  REVEAL   // 평문 열람 (사유 필수)
  EXPORT   // 열람권 행사 — 본인 데이터 내려받기
  UPDATE
  PROVIDE  // 제3자 제공 (배송사·PG 등)
  DELETE   // 파기
}

model User {
  id           String    @id @default(cuid())
  // --- 암호화 저장 컬럼 (AES-256-GCM) ---
  emailEnc     String
  emailHash    String    @unique // 블라인드 인덱스(HMAC) — 평문 없이 동등검색
  passwordHash String
  nameEnc      String
  phoneEnc     String?
  phoneHash    String?
  rrnEnc       String? // 주민등록번호: 최소수집 원칙, 본인인증 등 법적근거 있을 때만
  genderEnc    String? // 성별 M|F|OTHER (개인정보 — 암호화)
  birthDateEnc String? // 생년월일 YYYY-MM-DD (개인정보 — 암호화)
  // --- 비민감 메타 ---
  role         Role      @default(CUSTOMER)
  status       String    @default("ACTIVE") // ACTIVE | DORMANT | WITHDRAWN
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  dormantAt    DateTime? // 휴면 전환 시각 (장기 미접속 — 분리보관)
  withdrawnAt  DateTime? // 탈퇴 시각
  purgeAfter   DateTime? // 보관기간 만료 후 완전 파기 예정일

  consents            ConsentRecord[]
  addresses           Address[]
  paymentMethods      PaymentMethod[]
  provisions          ProvisionLog[]
  orders              Order[]
  inquiries           Inquiry[]
  accessLogsAsSubject PiiAccessLog[]  @relation("subject")
  accessLogsAsActor   PiiAccessLog[]  @relation("actor")

  @@index([status, purgeAfter])
}

model ConsentRecord {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      ConsentType
  version   String // 동의받은 약관/방침 버전
  granted   Boolean
  ip        String? // 동의 시점 증빙
  grantedAt DateTime    @default(now())
  revokedAt DateTime?

  @@index([userId, type])
}

model Address {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  label        String?
  recipientEnc String
  phoneEnc     String
  zipcode      String
  addr1Enc     String
  addr2Enc     String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// 결제수단 — 카드번호/계좌번호(민감·비밀정보)를 암호화 저장하는 지점.
// 노출은 브랜드+뒤 4자리만(cardLast4), 전체번호는 복호화 경로에서만.
model PaymentMethod {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  type          String   @default("CARD") // CARD | BANK
  // 카드
  cardBrand     String? // 비민감 (VISA/MASTER/... )
  cardLast4     String? // 마스킹 노출용 뒤 4자리
  cardNumberEnc String? // 전체 카드번호 (AES-256-GCM)
  cardExpiryEnc String? // 유효기간 MM/YY
  // 계좌(환불용)
  bankName      String?
  accountEnc    String? // 계좌번호 (AES-256-GCM)
  holderEnc     String? // 예금주명
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  priceKrw    Int
  stock       Int         @default(0)
  imageUrl    String?
  sellerId    String?
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
  inquiries   Inquiry[]
}

model Order {
  id           String      @id @default(cuid())
  user         User        @relation(fields: [userId], references: [id])
  userId       String
  status       String      @default("PENDING") // PENDING|PAID|SHIPPED|DONE|CANCELLED
  totalKrw     Int
  // 주문 시점 배송지 스냅샷 — 개인정보 암호화 저장 (주소록 변경과 무관하게 고정)
  recipientEnc String
  phoneEnc     String
  zipcode      String
  addr1Enc     String
  addr2Enc     String?
  createdAt    DateTime    @default(now())
  items        OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  qty       Int
  priceKrw  Int
}

// 제3자 제공 배치 — 여러 회원의 개인정보를 한 목적으로 묶어 외부에 제공한 "건"을 표현.
// 예: 마케팅 제휴사에 특정 조건 회원의 이름·연락처를 일괄 제공.
model ProvisionBatch {
  id           String         @id @default(cuid())
  recipientOrg String         // 제공받는 자
  purpose      String         // 제공 목적
  basis        String         // 제공 근거 (동의 | 법령 | 계약이행)
  items        String         // 제공 항목 (쉼표 구분)
  createdBy    String         // 제공 실행 관리자 uid
  count        Int            // 묶인 회원 수
  createdAt    DateTime       @default(now())
  provisions   ProvisionLog[]

  @@index([createdAt])
}

// 제3자 제공 대장(PIPA 제17조 · 제26조 위수탁) — 개인정보를 외부(배송사/PG/제휴사 등)에
// 제공한 사실을 기록. 제공 항목·목적·근거·제공받는 자를 남겨 정보주체 열람에 대응한다.
// 실제 전송은 하지 않고(테스트용) 제공 사실만 대장에 적재한다.
model ProvisionLog {
  id           String          @id @default(cuid())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  orderId      String?
  batch        ProvisionBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  batchId      String?
  recipientOrg String          // 제공받는 자 (예: CJ대한통운, 토스페이먼츠)
  items        String          // 제공 항목 (쉼표 구분: 이름,연락처,주소)
  purpose      String          // 제공 목적 (예: 상품 배송)
  basis        String          // 제공 근거 (동의 | 계약이행)
  providedAt   DateTime        @default(now())

  @@index([userId, providedAt])
  @@index([batchId])
}

// 1:1 고객 문의 — 답변 연락을 위해 연락처(개인정보)를 암호화 저장하는 또 하나의 PII 수집 지점.
// 상품 문의/배송 문의 등. 비회원도 남길 수 있으므로 userId는 선택.
model Inquiry {
  id           String    @id @default(cuid())
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?
  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId    String?
  category     String    @default("PRODUCT") // PRODUCT|DELIVERY|REFUND|ETC
  title        String
  body         String
  // --- 답변 연락용 개인정보 (암호화) ---
  nameEnc      String
  phoneEnc     String?
  emailEnc     String?
  status       String    @default("OPEN") // OPEN|ANSWERED|CLOSED
  answer       String?
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// 개인정보 접근 감사로그 (PIPA 제29조 안전조치 — 접근기록 보관·위변조 방지)
// 해시체인: 각 레코드 hash = SHA256(prevHash + 정규화된 내용). 한 행을 조작하면
// 그 이후 모든 hash가 어긋나 위·변조를 탐지할 수 있다.
model PiiAccessLog {
  seq           Int       @id @default(autoincrement()) // 체인 순서(결정적)
  logId         String    @unique @default(cuid())
  actor         User?     @relation("actor", fields: [actorId], references: [id])
  actorId       String?
  subject       User?     @relation("subject", fields: [subjectUserId], references: [id])
  subjectUserId String?
  action        PiiAction
  fields        String // 접근한 필드명 (쉼표 구분)
  reason        String? // REVEAL/EXPORT 시 사유 필수
  ip            String?
  userAgent     String?
  at            DateTime // 앱에서 설정(해시 대상에 포함되므로 DB default 미사용)
  prevHash      String? // 직전 레코드의 hash (제네시스는 null)
  hash          String // 이 레코드의 체인 해시

  @@index([subjectUserId, seq])
  @@index([actorId, seq])
}
