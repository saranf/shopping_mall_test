# --- 데이터베이스 ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartstore?schema=public"

# --- 개인정보 암호화 키 (운영에서는 반드시 KMS/Secret Manager로 관리) ---
# `npm run keygen` 으로 생성. base64 32바이트.
PII_ENCRYPTION_KEY=""   # 개인정보 컬럼 AES-256-GCM 암호화 키
PII_INDEX_KEY=""        # 블라인드 인덱스(HMAC) 키 — 암호화 키와 반드시 분리
SESSION_SECRET=""       # 세션 JWT 서명 키(임의 32바이트 이상)

# 운영 배포 시: NODE_ENV=production, 쿠키 secure 강제
